{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hydrospheric0.github.io/twitcher/data/frequency/schema.json",
  "title": "eBird frequency region dataset",
  "type": "object",
  "required": ["region", "generatedAt", "species"],
  "properties": {
    "region": { "type": "string" },
    "generatedAt": { "type": "string" },
    "source": { "type": "string" },
    "species": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["speciesCode", "comName", "sciName", "frequencyMonthly"],
        "properties": {
          "speciesCode": { "type": "string" },
          "comName": { "type": "string" },
          "sciName": { "type": "string" },
          "frequencyMonthly": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": { "type": "number" }
          },
          "frequencyWeekly": {
            "type": "array",
            "minItems": 48,
            "maxItems": 48,
            "items": { "type": "number" }
          },
          "frequencyAnnual": { "type": "number" }
        }
      }
    }
  }
}
